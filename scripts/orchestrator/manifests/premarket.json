{
  "task_type": "premarket",
  "description": "盘前速报数据采集（轻量版：仅隔夜消息+宏观）",
  "min_coverage": 0.5,
  "output_dir": "data/daily_inputs/{date}/",
  "scripts": [
    {
      "name": "macro_monitor",
      "command": "python3 scripts/data/macro_monitor.py all",
      "required": true,
      "timeout_s": 120,
      "purpose": "宏观+全球市场+FMP数据"
    },
    {
      "name": "rss_categorized",
      "command": "python3 scripts/data/rss_aggregator.py categorized",
      "required": false,
      "timeout_s": 60,
      "purpose": "隔夜财经新闻"
    },
    {
      "name": "research_strategy",
      "command": "python3 scripts/data/research_reports.py strategy",
      "required": false,
      "timeout_s": 60,
      "purpose": "卖方策略纪要"
    }
  ]
}
